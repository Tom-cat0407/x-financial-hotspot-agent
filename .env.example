X_MODE=mock
ENABLE_REAL_PUBLISH=false
REVIEW_REQUIRED=true
MAX_POSTS_PER_HOUR=6
PUBLISH_MAX_RETRIES=2
PUBLIC_BASE_URL=http://localhost:8000
USE_DATABASE=true
DATABASE_URL=postgresql+psycopg://agent:agent_password@localhost:5432/x_hotspot_agent
DB_FALLBACK_TO_JSON=true
ENABLE_SCHEDULER=false
COLLECTION_INTERVAL_MINUTES=5
ENABLE_AB_TESTING=true
ENABLE_EXTERNAL_FACT_SOURCES=false

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
# Replace with your own key locally. Never package or commit a populated .env file.
LLM_API_KEY=
DEEPSEEK_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_SECONDS=1.5
LLM_REASONING_EFFORT=
LLM_THINKING_ENABLED=false
ENABLE_LLM_NER=false
LLM_NER_MAX_POSTS_PER_RUN=8

# Optional: product demo narration audio.
# DEMO_TTS_PROVIDER=auto uses Volcengine/Doubao TTS first, then local Windows TTS fallback.
DEMO_TTS_PROVIDER=auto
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_SPEAKER=zh_female_cancan_uranus_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000
VOLCENGINE_TTS_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=10
THREADS_ENABLED=false
THREADS_MODE=mock
ALERT_WEBHOOK_URL=
ALERT_TIMEOUT_SECONDS=5

X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
